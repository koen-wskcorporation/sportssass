{
  "name": "orgframe-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev-launch.mjs",
    "dev:app": "node scripts/dev-launch.mjs app",
    "dev:web": "node scripts/dev-launch.mjs web",
    "build:app": "npm run build --workspace orgframe-app",
    "build:web": "npm run build --workspace orgframe-web",
    "lint:app": "npm run lint --workspace orgframe-app",
    "lint:web": "npm run lint --workspace orgframe-web",
    "typecheck:app": "npm run typecheck --workspace orgframe-app",
    "typecheck:web": "npm run typecheck --workspace orgframe-web"
  }
}
