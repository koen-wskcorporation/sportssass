# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Preferred public key for browser/server auth clients
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Server-only key for privileged operations
SUPABASE_SECRET_KEY=

# Public Google Maps key for address autocomplete in event forms
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Server-only OpenAI API key for AI Assistant
OPENAI_API_KEY=

# Optional model override for AI Assistant
OPENAI_MODEL=
# Google Sheets integration (service account)
GOOGLE_SHEETS_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SHEETS_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SHEETS_SERVICE_ACCOUNT_CLIENT_ID=

# Google Sheets inbound webhook verification secret
GOOGLE_SHEETS_WEBHOOK_HMAC_SECRET=

# Cron route bearer token for scheduled reconciliation
GOOGLE_SHEETS_CRON_BEARER_TOKEN=
